#!/bin/bash

# === AI CONSOLE ASSISTANT ===
# Version: 1.0.5
# Description: CLI assistant for Linux using Ollama API with stats and robust flow control

# === КОНСТАНТЫ И ПУТИ ===
CONF_FILE="$HOME/.ai_assistant.conf"
STATE_FILE="$HOME/.ai_config"

# Цвета
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'
GRAY='\033[0;90m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- ФУНКЦИИ УПРАВЛЕНИЯ КОНФИГОМ ---

prompt_for_host() {
    echo -e "${YELLOW}⚠️ Не удалось подключиться к текущему адресу.${NC}"
    echo -e "${WHITE}Введите адрес сервера Ollama (или нажмите Enter для localhost):${NC}"
    read -p "[http://localhost:11434]: " INPUT_HOST
    
    if [ -z "$INPUT_HOST" ]; then
        INPUT_HOST="http://localhost:11434"
    fi
    
    # Сохраняем в конфиг
    if [ ! -f "$CONF_FILE" ]; then
        echo "# AI Assistant Configuration" > "$CONF_FILE"
    fi
    # Обновляем или добавляем строку
    if grep -q "OLLAMA_HOST" "$CONF_FILE"; then
        sed -i "s|OLLAMA_HOST=.*|OLLAMA_HOST=\"${INPUT_HOST}\"|" "$CONF_FILE"
    else
        echo "OLLAMA_HOST=\"${INPUT_HOST}\"" >> "$CONF_FILE"
    fi
    
    echo -e "${GREEN}✅ Адрес сохранен: ${INPUT_HOST}${NC}"
    source "$CONF_FILE"
}

check_connection() {
    local tags_response
    tags_response=$(curl -s --connect-timeout 3 "${OLLAMA_HOST}/api/tags")
    if [ -z "$tags_response" ]; then
        return 1
    else
        return 0
    fi
}

init_config() {
    if [ ! -f "$CONF_FILE" ]; then
        echo -e "${CYAN}========================================${NC}"
        echo -e "${GREEN}👋 Добро пожаловать в AI Assistant!${NC}"
        echo -e "${CYAN}========================================${NC}"
        echo ""
        prompt_for_host
        
        # Проверяем соединение сразу после ввода
        if check_connection; then
            echo -e "${GREEN}✅ Подключение успешно установлено.${NC}"
        else
            echo -e "${RED}⚠️ Не удалось подключиться к ${OLLAMA_HOST}.${NC}"
            echo -e "${GRAY}Убедитесь, что Ollama запущен и доступен по сети.${NC}"
            echo -e "${GRAY}Вы можете изменить адрес позже командой: ai --set-host <url>${NC}"
            echo ""
        fi
    else
        source "$CONF_FILE"
    fi
}

set_host() {
    local new_host="$1"
    if [[ "$new_host" =~ ^https?:// ]]; then
        sed -i "s|OLLAMA_HOST=.*|OLLAMA_HOST=\"${new_host}\"|" "$CONF_FILE"
        echo -e "${GREEN}✅ Сервер изменен на: ${new_host}${NC}"
        rm -f "$STATE_FILE"
        echo -e "${YELLOW}⚠️ Список моделей сброшен. Выполните 'ai --update'.${NC}"
    else
        echo -e "${RED}❌ Неверный формат. Используйте http://ip:port${NC}"
        exit 1
    fi
    exit 0
}

list_models() {
    init_config
    echo -e "${BLUE}🔄 Загрузка списка моделей с ${OLLAMA_HOST}...${NC}"
    
    if ! check_connection; then
        prompt_for_host
        if ! check_connection; then
             echo -e "${RED}❌ Ошибка подключения. Проверьте сеть и адрес.${NC}"
             exit 1
        fi
    fi

    local tags_response
    tags_response=$(curl -s --connect-timeout 5 "${OLLAMA_HOST}/api/tags")
    local models
    models=$(echo "$tags_response" | jq -r '.models[].name')

    if [ -z "$models" ]; then
        echo -e "${YELLOW}Модели не найдены.${NC}"
        exit 0
    fi

    echo -e "${GREEN}✅ Доступные модели:${NC}"
    echo "$models" | while read -r line; do
        echo -e "  • ${line}"
    done
    exit 0
}

update_model_list() {
    init_config
    echo -e "${BLUE}🔄 Подключение к ${OLLAMA_HOST}...${NC}"
    
    if ! check_connection; then
        echo -e "${RED}❌ Ошибка подключения.${NC}"
        echo -e "${YELLOW}Хотите изменить адрес сервера? (y/n):${NC}"
        read -p "> " change_host
        if [[ "$change_host" =~ ^[Yy]$ ]]; then
            prompt_for_host
            if ! check_connection; then
                 echo -e "${RED}❌ Снова ошибка подключения. Проверьте настройки сети и запущен ли Ollama.${NC}"
                 exit 1
            fi
        else
            exit 1
        fi
    fi

    local tags_response
    tags_response=$(curl -s --connect-timeout 5 "${OLLAMA_HOST}/api/tags")
    local models
    models=$(echo "$tags_response" | jq -r '.models[].name')

    if [ -z "$models" ]; then
        echo -e "${RED}Модели не найдены на сервере.${NC}"
        exit 1
    fi

    {
        echo "# AI State Config"
        echo "LAST_MODEL=\"\""
        echo "MODELS=("
        while IFS= read -r line; do
            echo "  \"$line\""
        done <<< "$models"
        echo ")"
    } > "$STATE_FILE"
    
    echo -e "${GREEN}✅ Список моделей сохранен.${NC}"
    exit 0
}

load_state() {
    if [ ! -f "$STATE_FILE" ]; then
        # Если файла состояния нет, пытаемся обновить его с сервера
        update_model_list
    else
        source "$STATE_FILE"
    fi
}

select_model_interactive() {
    # Если файла состояния нет, создаем его через update_model_list
    if [ ! -f "$STATE_FILE" ]; then
        update_model_list
        # После обновления перечитываем файл
        if [ -f "$STATE_FILE" ]; then
            source "$STATE_FILE"
        else
            # Если update не создал файл (ошибка сети), переходим к ручному вводу ниже
            MODELS=()
        fi
    else
        source "$STATE_FILE"
    fi

    # Проверяем, есть ли модели в списке И работает ли сервер
    if [ ${#MODELS[@]} -eq 0 ]; then
        echo -e "${YELLOW}⚠️ Список моделей пуст. Пробую подключиться к ${OLLAMA_HOST}...${NC}"
        if check_connection; then
            # Если сервер доступен, но список пуст — значит, там реально нет моделей
            echo -e "${RED}❌ Сервер доступен, но на нем нет установленных моделей.${NC}"
            echo -e "${GRAY}Установите модель командой: ollama pull qwen2.5-coder:7b${NC}"
            exit 1
        else
            # Если сервер НЕ доступен, предлагаем ручной ввод
            echo -e "${RED}⚠️ Не удалось подключиться к ${OLLAMA_HOST}.${NC}"
            echo -e "${WHITE}Введите имя модели вручную (например, qwen2.5-coder:7b):${NC}"
            read -p "> " MANUAL_MODEL
            if [ -n "$MANUAL_MODEL" ]; then
                SELECTED_MODEL="$MANUAL_MODEL"
                save_last_model "$SELECTED_MODEL"
                echo -e "${GREEN}✅ Модель ${SELECTED_MODEL} сохранена.${NC}"
                # Если вопроса нет, выходим
                if [ -z "$USER_QUERY" ]; then
                    echo -e "${GRAY}Теперь задайте вопрос, например: ai как дела${NC}"
                    exit 0
                fi
                return
            else
                echo -e "${RED}Ошибка: имя модели не может быть пустым.${NC}"
                exit 1
            fi
        fi
    fi

    # Если список моделей есть, показываем меню
    echo -e "${BLUE}📚 Выберите модель для работы:${NC}"
    local i=1
    local model_array=("${MODELS[@]}")
    for model in "${model_array[@]}"; do
        echo -e "  ${GREEN}${i})${NC} ${model}"
        ((i++))
    done
    read -p "Номер модели: " num
    if [[ "$num" =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#model_array[@]}" ]; then
        SELECTED_MODEL="${model_array[$((num-1))]}"
    else
        SELECTED_MODEL="${model_array[0]}"
    fi
    save_last_model "$SELECTED_MODEL"
    echo -e "${GREEN}✅ Модель ${SELECTED_MODEL} сохранена как основная.${NC}"
    
    # Если это был интерактивный запуск без вопроса, завершаем работу
    if [ -z "$USER_QUERY" ]; then
        echo -e "${GRAY}Теперь задайте вопрос, например: ai как дела${NC}"
        exit 0
    fi
}

save_last_model() {
    if [ ! -f "$STATE_FILE" ]; then
        echo "LAST_MODEL=\"\"" > "$STATE_FILE"
        echo "MODELS=()" >> "$STATE_FILE"
    fi
    sed -i "s/LAST_MODEL=.*/LAST_MODEL=\"$1\"/" "$STATE_FILE"
}

# --- СПРАВКА ---

show_help() {
    init_config
    load_state 2>/dev/null || true
    
    echo -e "${CYAN}========================================${NC}"
    echo -e "${CYAN}       AI Console Assistant Help        ${NC}"
    echo -e "${CYAN}========================================${NC}"
    echo ""
    echo -e "${WHITE}Текущие настройки:${NC}"
    echo -e "  ${GRAY}Сервер Ollama:${NC} ${OLLAMA_HOST}"
    echo -e "  ${GRAY}Модель по умолчанию:${NC} ${LAST_MODEL:-не выбрана}"
    echo ""
    echo -e "${WHITE}Использование:${NC}"
    echo -e "  ${GREEN}ai${NC} <ваш вопрос>"
    echo ""
    echo -e "${WHITE}Опции:${NC}"
    echo -e "  ${GREEN}-h, --help${NC}       Показать эту справку"
    echo -e "  ${GREEN}-l, --list${NC}       Показать список моделей на сервере"
    echo -e "  ${GREEN}-m <модель>${NC}      Выбрать и СОХРАНИТЬ модель"
    echo -e "  ${GREEN}-t, --text${NC}       Режим чата (без выполнения команд)"
    echo -e "  ${GREEN}--set-host <URL>${NC} Изменить адрес сервера"
    echo -e "  ${GREEN}--update${NC}         Обновить локальный список моделей"
    echo -e "  ${GREEN}--reset${NC}          Сбросить выбор модели"
    echo ""
    echo -e "${GRAY}Совет: Используйте модели qwen2.5-coder для лучших результатов.${NC}"
    echo -e "${CYAN}========================================${NC}"
    exit 0
}

# --- ОСНОВНАЯ ЛОГИКА ---

init_config
IS_CMD_MODE=true
USER_QUERY=""
SELECTED_MODEL=""

ARGS=()
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -h|--help) show_help ;;
        -l|--list) list_models ;;
        --set-host) 
            if [ -n "$2" ]; then set_host "$2"; else echo "Укажите URL"; exit 1; fi ;;
        --update) update_model_list ;;
        --reset) 
            sed -i 's/LAST_MODEL=".*"/LAST_MODEL=""/' "$STATE_FILE" 2>/dev/null
            echo -e "${YELLOW}Сброшено.${NC}"
            select_model_interactive
            exit 0
            ;;
        -t|--text) IS_CMD_MODE=false; shift ;;
        -m) 
            if [ -n "$2" ]; then
                save_last_model "$2"
                SELECTED_MODEL="$2"
                echo -e "${GREEN}✅ Модель сохранена: $2${NC}"
                shift 2
            else
                echo "Ошибка: укажите модель после -m"; exit 1
            fi
            ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

USER_QUERY="${ARGS[*]}"

# Если вопрос не задан, обрабатываем интерактивный режим
if [ -z "$USER_QUERY" ]; then
    if [ -z "$SELECTED_MODEL" ]; then
         load_state
         if [ -z "$LAST_MODEL" ] || [ "$LAST_MODEL" == "" ]; then
             select_model_interactive
             # select_model_interactive сама вызовет exit 0, если вопроса нет
         else
             SELECTED_MODEL="$LAST_MODEL"
             show_help
         fi
    else
        show_help
    fi
fi

# Загрузка состояния, если модель не была задана явно через -m
if [ -z "$SELECTED_MODEL" ]; then
    load_state
    if [ -n "$LAST_MODEL" ]; then
        SELECTED_MODEL="$LAST_MODEL"
    else
        select_model_interactive
    fi
fi

echo -e "${GRAY}[Сервер: ${OLLAMA_HOST} | Модель: ${SELECTED_MODEL}]${NC}"
if [ "$IS_CMD_MODE" = true ]; then
    echo -e "${GRAY}[Режим: КОМАНДА]${NC}"
else
    echo -e "${GRAY}[Режим: ТЕКСТ]${NC}"
fi

echo -e "${BLUE}🤖 Думаю...${NC}"

# Промпты
if [ "$IS_CMD_MODE" = true ]; then
    SYSTEM_PROMPT="You are a Linux CLI assistant. 
    Return ONLY a raw JSON object with keys: 'command', 'explanation', 'is_safe'.
    
    Rules:
    1. 'command': Valid bash command. NO placeholders like <file>. Use '*' or '.' if needed.
    2. 'explanation': Short explanation in RUSSIAN.
    3. 'is_safe': Boolean (true/false).
    
    Example: 
    {\"command\": \"find / -name '*.log' -size +100M\", \"explanation\": \"Поиск логов больше 100МБ\", \"is_safe\": true}"
else
    SYSTEM_PROMPT="You are a helpful assistant. Answer in Russian. Be concise."
fi

FULL_PROMPT="${SYSTEM_PROMPT}

User task: ${USER_QUERY}"

RESPONSE=$(curl -s -X POST "${OLLAMA_HOST}/api/generate" \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"${SELECTED_MODEL}\",
        \"prompt\": \"$(echo "$FULL_PROMPT" | sed 's/"/\\"/g' | tr '\n' ' ')\",
        \"stream\": false,
        \"options\": { \"temperature\": 0.1 }
    }")

RAW_RESPONSE=$(echo "$RESPONSE" | jq -r '.response // empty')

# === СТАТИСТИКА ===
# Извлекаем метрики из полного JSON ответа
TOKENS_PROMPT=$(echo "$RESPONSE" | jq -r '.prompt_eval_count // 0')
TOKENS_GENERATED=$(echo "$RESPONSE" | jq -r '.eval_count // 0')
DURATION_NS=$(echo "$RESPONSE" | jq -r '.total_duration // 0')
LOAD_DURATION_NS=$(echo "$RESPONSE" | jq -r '.load_duration // 0')

# Конвертируем наносекунды в секунды и миллисекунды
if [ "$DURATION_NS" -gt 0 ] 2>/dev/null; then
    TOTAL_SEC=$(awk "BEGIN {printf \"%.2f\", $DURATION_NS/1000000000}")
    LOAD_MS=$(awk "BEGIN {printf \"%.0f\", $LOAD_DURATION_NS/1000000}")
    
    # Считаем скорость генерации (токенов в секунду)
    # Исключаем время загрузки модели из расчета скорости генерации, если оно было значительным
    GEN_DURATION_NS=$((DURATION_NS - LOAD_DURATION_NS))
    if [ "$GEN_DURATION_NS" -lt 0 ]; then GEN_DURATION_NS=$DURATION_NS; fi
    
    if [ "$TOKENS_GENERATED" -gt 0 ]; then
        SPEED=$(awk "BEGIN {printf \"%.1f\", $TOKENS_GENERATED / ($GEN_DURATION_NS/1000000000)}")
    else
        SPEED="0.0"
    fi
else
    TOTAL_SEC="0.00"
    LOAD_MS="0"
    SPEED="0.0"
fi

if [ "$IS_CMD_MODE" = true ]; then
    CLEAN_JSON=$(echo "$RAW_RESPONSE" | sed 's/```json//g; s/```//g; s/^ *//; s/ *$//')
    CMD_LINE=$(echo "$CLEAN_JSON" | jq -r '.command // empty' 2>/dev/null)
    EXPL_LINE=$(echo "$CLEAN_JSON" | jq -r '.explanation // empty' 2>/dev/null)
    IS_SAFE=$(echo "$CLEAN_JSON" | jq -r '.is_safe // true' 2>/dev/null)

    CMD_LINE=$(echo "$CMD_LINE" | sed 's/<[^>]*>//g; s/\[[^]]*\]//g' | xargs)

    if [ -z "$CMD_LINE" ] || [ "$CMD_LINE" == "null" ]; then
        echo -e "${YELLOW}⚠️ Команда не получена.${NC}"
        exit 0
    fi

    echo -e "${GREEN}✅ Команда:${NC}"
    echo -e "${WHITE}${CMD_LINE}${NC}"
    echo ""
    echo -e "${YELLOW}💡 Пояснение:${NC} ${EXPL_LINE}"
    
    if [ "$IS_SAFE" == "false" ]; then
        echo -e "${RED}⚠️ ОПАСНО: Модель предупреждает о риске!${NC}"
    fi

    echo ""
    
    # Вывод статистики для режима команд
    echo -e "${GRAY}--- Статистика ---${NC}"
    echo -e "${GRAY}Токены (вопрос): ${TOKENS_PROMPT} | Токены (ответ): ${TOKENS_GENERATED}${NC}"
    echo -e "${GRAY}Время: ${TOTAL_SEC} сек (загрузка: ${LOAD_MS} мс) | Скорость: ${SPEED} т/с${NC}"
    echo -e "${GRAY}------------------${NC}"
    echo ""

    read -p "Действие: [Enter]-Запустить, e-Редактировать, n-Отмена: " choice

    case "$choice" in 
      e|E )
        read -e -i "$CMD_LINE" -p "> " EDITED_CMD
        if [ -n "$EDITED_CMD" ]; then
            eval "$EDITED_CMD"
        fi
        ;;
      n|N ) echo -e "${RED}❌ Отменено.${NC}" ;;
      * ) eval "$CMD_LINE" ;;
    esac
else
    echo -e "${GREEN}🤖 Ответ:${NC}"
    echo -e "${WHITE}${RAW_RESPONSE}${NC}"
    
    # Вывод статистики для режима чата
    echo ""
    echo -e "${GRAY}--- Статистика ---${NC}"
    echo -e "${GRAY}Токены (вопрос): ${TOKENS_PROMPT} | Токены (ответ): ${TOKENS_GENERATED}${NC}"
    echo -e "${GRAY}Время: ${TOTAL_SEC} сек (загрузка: ${LOAD_MS} мс) | Скорость: ${SPEED} т/с${NC}"
    echo -e "${GRAY}------------------${NC}"
fi
